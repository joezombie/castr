@page
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Security.Claims
@model Castr.Pages.LoginModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Castr</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; }
        body {
            background-color: #121009;
            color: #f4f1ea;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Hanken Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .login-wrap { width: 340px; }
        .login-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 26px;
        }
        .login-brand .logo {
            width: 30px; height: 30px; border-radius: 8px; background: #ef6b41;
            display: flex; align-items: center; justify-content: center;
        }
        .login-brand .logo .dot { width: 9px; height: 9px; border-radius: 50%; background: #121009; }
        .login-brand .name { font-size: 22px; font-weight: 800; letter-spacing: -.02em; }
        .login-container {
            background-color: #1d1b14;
            border: 1px solid #28241c;
            padding: 26px;
            border-radius: 16px;
        }
        .login-title {
            text-align: center;
            margin: 0 0 18px;
            font-size: 17px;
            font-weight: 700;
        }
        .form-group { margin-bottom: 14px; }
        .form-label {
            display: block;
            margin-bottom: 6px;
            font-size: 12.5px;
            font-weight: 600;
            color: #b4ad9e;
        }
        .form-input {
            width: 100%;
            padding: 11px 13px;
            border: 1px solid #2f2a20;
            border-radius: 9px;
            background-color: #15140f;
            color: #f4f1ea;
            font-size: 14px;
            font-family: inherit;
        }
        .form-input::placeholder { color: #5e584c; }
        .form-input:focus { outline: none; border-color: #ef6b41; }
        .btn-login {
            width: 100%;
            padding: 12px;
            background-color: #ef6b41;
            color: #1a120d;
            border: none;
            border-radius: 9px;
            font-size: 14.5px;
            font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            margin-top: 6px;
        }
        .btn-login:hover { filter: brightness(1.07); }
        .error-message {
            background-color: rgba(224, 97, 79, .12);
            border: 1px solid rgba(224, 97, 79, .3);
            color: #e0614f;
            padding: 0.75rem;
            border-radius: 9px;
            margin-bottom: 14px;
            font-size: 13px;
        }
        .login-foot {
            text-align: center;
            font-size: 12px;
            color: #5e584c;
            margin-top: 16px;
            font-family: 'JetBrains Mono', monospace;
        }
    </style>
</head>
<body>
    <div class="login-wrap">
        <div class="login-brand">
            <div class="logo"><div class="dot"></div></div>
            <span class="name">Castr</span>
        </div>
        <div class="login-container">
            <h1 class="login-title">Sign in to your server</h1>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error-message">@Model.ErrorMessage</div>
            }

            <form method="post">
                <input type="hidden" name="returnUrl" value="@Request.Query["ReturnUrl"]" />
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label" for="username">Username</label>
                    <input class="form-input" type="text" id="username" name="username" required autocomplete="username" />
                </div>
                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input class="form-input" type="password" id="password" name="password" required autocomplete="current-password" />
                </div>
                <button class="btn-login" type="submit">Sign in</button>
            </form>
        </div>
        <div class="login-foot">castr · self-hosted podcast server</div>
    </div>
</body>
</html>
