@page "/ui"
@attribute [Authorize]
@inject IPodcastDataService DataService
@inject ILogger<Dashboard> Logger
@inject NavigationManager Navigation
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using Castr.Data.Entities
@using DownloadQueueItemEntity = Castr.Data.Entities.DownloadQueueItem

<PageTitle>Dashboard - Castr</PageTitle>

<div class="castr-page">
    <div style="margin-bottom:24px;">
        <h1 class="castr-h1">Overview</h1>
        <p class="castr-subtitle">Everything Castr is serving and downloading, at a glance.</p>
    </div>

    <!-- stat cards -->
    <div class="castr-stat-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px;">
        <div class="castr-card cursor-pointer" @onclick="GoToFeeds">
            <div class="castr-stat-label">Feeds</div>
            <div class="castr-stat-number">@_feedCount</div>
            <div class="castr-stat-sub">@_monitoredCount monitored on YouTube</div>
        </div>
        <div class="castr-card cursor-pointer" @onclick="GoToFeeds">
            <div class="castr-stat-label">Episodes</div>
            <div class="castr-stat-number">@_episodeCount</div>
            <div class="castr-stat-sub">across all feeds</div>
        </div>
        <div class="castr-card">
            <div class="castr-stat-label">Storage used</div>
            <div class="castr-stat-number">@_storageDisplay</div>
            <div class="castr-stat-sub">on disk</div>
        </div>
        <div class="castr-card cursor-pointer" @onclick="GoToDownloads">
            <div class="castr-stat-label">Active downloads</div>
            <div class="castr-stat-number @(_activeDownloads > 0 ? "castr-stat-number--accent" : "")">@_activeDownloads</div>
            <div class="castr-stat-sub">@_queuedCount queued behind</div>
        </div>
    </div>

    <!-- downloading now -->
    @if (_activeDownloadItems.Any())
    {
        <div class="castr-card castr-card--pad20" style="margin-bottom:18px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                <div style="display:flex;align-items:center;gap:9px;">
                    <span class="castr-pulse-dot"></span>
                    <h2 class="castr-h2">Downloading now</h2>
                </div>
                <a class="cursor-pointer" style="font-size:13px;font-weight:600;color:var(--accent);text-decoration:none;" @onclick="GoToDownloads">View queue →</a>
            </div>
            <div style="display:flex;flex-direction:column;gap:16px;">
                @foreach (var item in _activeDownloadItems)
                {
                    <div>
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;gap:12px;">
                            <div style="display:flex;align-items:center;gap:10px;min-width:0;">
                                <div class="castr-avatar" style="width:30px;height:30px;border-radius:7px;background:@FeedColor(_feedNames.GetValueOrDefault(item.FeedId, "?"));"></div>
                                <div style="min-width:0;">
                                    <div style="font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(item.VideoTitle ?? item.VideoId)</div>
                                    <div style="font-size:12px;color:var(--text-label);">@(_feedNames.GetValueOrDefault(item.FeedId, "Unknown"))</div>
                                </div>
                            </div>
                            <div class="castr-mono" style="text-align:right;flex-shrink:0;">
                                <div style="font-size:14px;font-weight:600;color:var(--accent);">@item.ProgressPercent%</div>
                                <div style="font-size:11px;color:var(--text-faint);">@item.Status</div>
                            </div>
                        </div>
                        <div class="castr-rail">
                            <div class="castr-rail__fill" style="width:@(item.ProgressPercent)%;"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- two columns -->
    <div class="castr-dash-cols" style="display:grid;grid-template-columns:1.5fr 1fr;gap:18px;">
        <!-- recent activity -->
        <div class="castr-card castr-card--pad20">
            <h2 class="castr-h2" style="margin-bottom:16px;">Recent activity</h2>
            @if (_recentActivity.Any())
            {
                <div style="display:flex;flex-direction:column;">
                    @foreach (var activity in _recentActivity)
                    {
                        <div style="display:flex;gap:13px;padding:9px 0;border-bottom:1px solid var(--border-row);">
                            <span style="width:8px;height:8px;border-radius:50%;margin-top:6px;flex-shrink:0;background:@ActivityColor(activity.ActivityType);"></span>
                            <div style="min-width:0;">
                                <div style="font-size:13.5px;line-height:1.45;color:var(--text-strong);">@activity.Message</div>
                                <div class="castr-mono" style="font-size:11.5px;color:var(--text-faint);margin-top:2px;">@activity.CreatedAt.ToString("g")</div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="padding:24px;text-align:center;color:var(--text-faint);font-size:14px;">No recent activity</div>
            }
        </div>

        <!-- right column -->
        <div style="display:flex;flex-direction:column;gap:18px;">
            <div class="castr-card castr-card--pad20">
                <h2 class="castr-h2" style="margin-bottom:14px;">Upcoming polls</h2>
                @if (_upcomingPolls.Any())
                {
                    <div style="display:flex;flex-direction:column;gap:11px;">
                        @foreach (var f in _upcomingPolls)
                        {
                            <div class="cursor-pointer" style="display:flex;align-items:center;gap:11px;" @onclick="() => GoToFeed(f.Name)">
                                <div class="castr-avatar castr-avatar--sm" style="background:@FeedColor(f.Title);">@Initials(f.Title)</div>
                                <div style="min-width:0;flex:1;">
                                    <div style="font-size:13.5px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@f.Title</div>
                                    <div style="font-size:11.5px;color:var(--text-faint);">every @f.YouTubePollIntervalMinutes min</div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="font-size:13px;color:var(--text-faint);">No playlists are being monitored.</div>
                }
            </div>

            <div class="castr-card castr-card--pad20">
                <h2 class="castr-h2" style="margin-bottom:14px;">Storage by feed</h2>
                @if (_storageByFeed.Any())
                {
                    <div style="display:flex;flex-direction:column;gap:13px;">
                        @foreach (var f in _storageByFeed)
                        {
                            <div>
                                <div style="display:flex;justify-content:space-between;font-size:12.5px;margin-bottom:5px;">
                                    <span style="color:var(--text-strong);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@f.Title</span>
                                    <span class="castr-mono" style="color:var(--text-label);flex-shrink:0;margin-left:8px;">@FormatSize(f.Bytes)</span>
                                </div>
                                <div class="castr-rail castr-rail--thin">
                                    <div class="castr-rail__fill" style="width:@(StoragePct(f.Bytes))%;background:@FeedColor(f.Title);transition:none;"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="font-size:13px;color:var(--text-faint);">No stored episodes yet.</div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private static readonly DateTime _startTime = DateTime.UtcNow;

    private int _feedCount;
    private int _episodeCount;
    private int _activeDownloads;
    private string _uptime = "0s";
    private List<DownloadQueueItemEntity> _activeDownloadItems = new();
    private List<ActivityLog> _recentActivity = new();
    private HubConnection? _hubConnection;
    private System.Threading.Timer? _refreshTimer;
    private bool _disposed;

    // UI display data (derived from existing DataService calls — no backend changes)
    private int _monitoredCount;
    private int _queuedCount;
    private long _totalBytes;
    private string _storageDisplay = "0 B";
    private long _maxFeedBytes;
    private Dictionary<int, string> _feedNames = new();
    private List<Feed> _upcomingPolls = new();
    private List<(string Title, long Bytes)> _storageByFeed = new();

    protected override async Task OnInitializedAsync()
    {
        Logger.LogDebug("Dashboard page initialized");

        await LoadStatisticsAsync();

        // Set up SignalR connection
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/download-progress"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<int, int, int>("StatisticsUpdated", async (feeds, episodes, downloads) =>
        {
            _feedCount = feeds;
            _episodeCount = episodes;
            _activeDownloads = downloads;
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<int, string, int>("DownloadProgress", async (feedId, videoId, percent) =>
        {
            var item = _activeDownloadItems.FirstOrDefault(x => x.VideoId == videoId);
            if (item != null)
            {
                item.ProgressPercent = percent;
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<string, string, int?>("ActivityLogged", async (type, message, feedId) =>
        {
            await LoadStatisticsAsync();
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            Logger.LogDebug("SignalR connection established");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to connect to SignalR hub");
        }

        // Refresh statistics every 30 seconds
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            try
            {
                await LoadStatisticsAsync();
                UpdateUptime();
                await InvokeAsync(StateHasChanged);
            }
            catch (ObjectDisposedException)
            {
                // Expected during disposal, ignore
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error in dashboard refresh timer");
            }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadStatisticsAsync()
    {
        try
        {
            var feeds = await DataService.GetAllFeedsAsync();
            _feedCount = feeds.Count;
            _monitoredCount = feeds.Count(f => f.YouTubeEnabled);
            _feedNames = feeds.ToDictionary(f => f.Id, f => f.Title);
            _upcomingPolls = feeds
                .Where(f => f.YouTubeEnabled)
                .OrderBy(f => f.YouTubePollIntervalMinutes)
                .Take(4)
                .ToList();

            _episodeCount = 0;
            _totalBytes = 0;
            var perFeed = new List<(string Title, long Bytes)>();
            foreach (var feed in feeds)
            {
                var episodes = await DataService.GetEpisodesAsync(feed.Id);
                _episodeCount += episodes.Count;
                var bytes = episodes.Sum(e => e.FileSize ?? 0L);
                _totalBytes += bytes;
                if (bytes > 0)
                {
                    perFeed.Add((feed.Title, bytes));
                }
            }
            _storageDisplay = FormatSize(_totalBytes);
            _storageByFeed = perFeed.OrderByDescending(f => f.Bytes).Take(4).ToList();
            _maxFeedBytes = _storageByFeed.Count > 0 ? _storageByFeed.Max(f => f.Bytes) : 0;

            var queue = await DataService.GetQueueAsync();
            _activeDownloadItems = queue.Where(q => q.Status == "downloading" || q.Status == "queued").ToList();
            _activeDownloads = _activeDownloadItems.Count;
            _queuedCount = queue.Count(q => q.Status == "queued");

            _recentActivity = await DataService.GetRecentActivityAsync(count: 20);

            UpdateUptime();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard statistics");
        }
    }

    private void UpdateUptime()
    {
        var uptime = DateTime.UtcNow - _startTime;
        if (uptime.TotalDays >= 1)
            _uptime = $"{(int)uptime.TotalDays}d {uptime.Hours}h";
        else if (uptime.TotalHours >= 1)
            _uptime = $"{(int)uptime.TotalHours}h {uptime.Minutes}m";
        else
            _uptime = $"{uptime.Minutes}m {uptime.Seconds}s";
    }

    // --- UI helpers (presentation only) ---
    private static readonly string[] AvatarPalette =
        { "#a8794a", "#b5683f", "#4f7d6e", "#8a5168", "#6a6aa3", "#4d7a99" };

    private static string FeedColor(string name)
    {
        if (string.IsNullOrEmpty(name)) return AvatarPalette[0];
        int hash = 0;
        foreach (var c in name) hash = (hash * 31 + c) & 0x7fffffff;
        return AvatarPalette[hash % AvatarPalette.Length];
    }

    private static string Initials(string title)
    {
        if (string.IsNullOrWhiteSpace(title)) return "?";
        var parts = title.Split(new[] { ' ', '-', '_' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return ($"{parts[0][0]}{parts[1][0]}").ToUpperInvariant();
    }

    private static string FormatSize(long bytes)
    {
        if (bytes <= 0) return "0 B";
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        double size = bytes;
        int unit = 0;
        while (size >= 1024 && unit < units.Length - 1) { size /= 1024; unit++; }
        return size >= 100 || unit == 0 ? $"{size:0} {units[unit]}" : $"{size:0.0} {units[unit]}";
    }

    private int StoragePct(long bytes)
    {
        if (_maxFeedBytes <= 0) return 0;
        return (int)Math.Round(bytes * 100.0 / _maxFeedBytes);
    }

    private static string ActivityColor(string activityType) => activityType switch
    {
        "download" => "#5bbf8a",
        "error" => "#e0614f",
        "warning" => "#e0b04a",
        "sync" => "#7f8aa0",
        _ => "#ef6b41"
    };

    private void GoToFeeds() => Navigation.NavigateTo("/ui/feeds");
    private void GoToDownloads() => Navigation.NavigateTo("/ui/downloads");
    private void GoToFeed(string name) => Navigation.NavigateTo($"/ui/feeds/{name}");

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _refreshTimer?.Dispose();
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
