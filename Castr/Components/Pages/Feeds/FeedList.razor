@page "/ui/feeds"
@attribute [Authorize]
@inject IPodcastDataService DataService
@inject ILogger<FeedList> Logger
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Castr.Data.Entities

<PageTitle>Feeds - Castr</PageTitle>

<div class="castr-page">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:14px;margin-bottom:24px;">
        <div>
            <h1 class="castr-h1">Feeds</h1>
            <p class="castr-subtitle">@_feeds.Count feeds · @_monitoredCount monitoring YouTube playlists</p>
        </div>
        <button class="castr-btn castr-btn--primary" @onclick="CreateNewFeed">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            New feed
        </button>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_feeds.Any())
    {
        <div class="castr-feed-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:16px;">
            @foreach (var feed in _feeds)
            {
                var episodes = _episodeCounts.GetValueOrDefault(feed.Id, 0);
                <div class="castr-card castr-card-hover" style="cursor:pointer;position:relative;" @onclick="() => ViewFeed(feed)">
                    <div style="display:flex;gap:14px;">
                        <div class="castr-avatar castr-avatar--lg" style="background:@AvatarColor(feed.Title)">@Initials(feed.Title)</div>
                        <div style="min-width:0;flex:1;">
                            <div style="display:flex;align-items:center;gap:8px;padding-right:32px;">
                                <h3 style="margin:0;font-size:15.5px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text-primary);">@feed.Title</h3>
                            </div>
                            <div style="font-size:13px;color:#8b8475;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(string.IsNullOrWhiteSpace(feed.Author) ? feed.Name : feed.Author)</div>
                            <div class="castr-pill" style="margin-top:8px;">
                                <span class="castr-pill__dot" style="background:@StatusColor(feed)"></span>
                                <span class="castr-pill__label">@StatusLabel(feed)</span>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(feed.Description))
                    {
                        <p style="margin:14px 0 0;font-size:13px;line-height:1.5;color:#928b7c;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@feed.Description</p>
                    }

                    <div class="castr-mono" style="display:flex;align-items:flex-end;gap:20px;margin-top:14px;padding-top:14px;border-top:1px solid var(--border-row);">
                        <div style="white-space:nowrap;">
                            <div style="font-size:14px;font-weight:600;line-height:1.2;color:var(--text-primary);">@episodes</div>
                            <div style="font-size:10.5px;color:#645e52;font-family:'Hanken Grotesk',sans-serif;margin-top:2px;">episodes</div>
                        </div>
                        @if (feed.YouTubeEnabled)
                        {
                            <div style="margin-left:auto;text-align:right;white-space:nowrap;">
                                <div style="font-size:13px;font-weight:600;line-height:1.2;color:var(--accent);">every @feed.YouTubePollIntervalMinutes m</div>
                                <div style="font-size:10.5px;color:#645e52;font-family:'Hanken Grotesk',sans-serif;margin-top:2px;">poll interval</div>
                            </div>
                        }
                    </div>

                    <div style="position:absolute;top:14px;right:14px;display:flex;gap:6px;" @onclick:stopPropagation="true">
                        <button class="castr-icon-btn" title="Edit" @onclick="() => EditFeed(feed)" @onclick:stopPropagation="true">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4Z" /></svg>
                        </button>
                        <button class="castr-icon-btn" title="Delete" style="color:var(--status-error);" @onclick="() => DeleteFeed(feed)" @onclick:stopPropagation="true">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="castr-card" style="text-align:center;padding:48px 24px;">
            <div style="font-size:18px;font-weight:700;color:var(--text-primary);margin-bottom:6px;">No feeds yet</div>
            <p style="font-size:13.5px;color:#928b7c;margin:0 0 20px;">Create your first podcast feed to get started.</p>
            <button class="castr-btn castr-btn--primary" style="margin:0 auto;" @onclick="CreateNewFeed">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                New feed
            </button>
        </div>
    }
</div>

<style>
    @@media (max-width: 760px) {
        .castr-feed-grid { grid-template-columns: 1fr !important; }
    }
</style>

@code {
    private List<Feed> _feeds = new();
    private Dictionary<int, int> _episodeCounts = new();
    private bool _loading = true;

    private int _monitoredCount => _feeds.Count(f => f.YouTubeEnabled);

    // Pure UI helpers (presentation only)
    private static readonly string[] AvatarPalette =
        { "#a8794a", "#b5683f", "#4f7d6e", "#8a5168", "#6a6aa3", "#4d7a99" };

    private static string AvatarColor(string name)
    {
        if (string.IsNullOrEmpty(name))
            return AvatarPalette[0];
        unchecked
        {
            int hash = 0;
            foreach (var c in name)
                hash = hash * 31 + c;
            int idx = Math.Abs(hash) % AvatarPalette.Length;
            return AvatarPalette[idx];
        }
    }

    private static string Initials(string title)
    {
        if (string.IsNullOrWhiteSpace(title))
            return "?";
        var words = title.Split(new[] { ' ', '-', '_', '\t' }, StringSplitOptions.RemoveEmptyEntries);
        if (words.Length == 0)
            return "?";
        if (words.Length == 1)
            return words[0].Substring(0, Math.Min(2, words[0].Length)).ToUpperInvariant();
        return (words[0].Substring(0, 1) + words[1].Substring(0, 1)).ToUpperInvariant();
    }

    private static string StatusColor(Feed feed)
    {
        if (!feed.IsActive)
            return "#e0614f"; // error
        if (feed.YouTubeEnabled)
            return "#5bbf8a"; // success / monitoring
        return "#7f8aa0"; // neutral local
    }

    private static string StatusLabel(Feed feed)
    {
        if (!feed.IsActive)
            return "Inactive";
        if (feed.YouTubeEnabled)
            return "Monitoring";
        return "Local only";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadFeedsAsync();
    }

    private async Task LoadFeedsAsync()
    {
        _loading = true;
        try
        {
            _feeds = await DataService.GetAllFeedsAsync();
            _episodeCounts.Clear();
            foreach (var feed in _feeds)
            {
                var episodes = await DataService.GetEpisodesAsync(feed.Id);
                _episodeCounts[feed.Id] = episodes.Count;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load feeds");
            Snackbar.Add("Failed to load feeds", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void CreateNewFeed()
    {
        Navigation.NavigateTo("/ui/feeds/new");
    }

    private void ViewFeed(Feed feed)
    {
        Navigation.NavigateTo($"/ui/feeds/{feed.Name}");
    }

    private void EditFeed(Feed feed)
    {
        Navigation.NavigateTo($"/ui/feeds/{feed.Name}/edit");
    }

    private async Task DeleteFeed(Feed feed)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Feed",
            $"Are you sure you want to delete '{feed.Title}'? This will also delete all associated episodes and download history.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await DataService.DeleteFeedAsync(feed.Id);
                Snackbar.Add($"Feed '{feed.Title}' deleted", Severity.Success);
                await LoadFeedsAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to delete feed {FeedId}", feed.Id);
                Snackbar.Add("Failed to delete feed", Severity.Error);
            }
        }
    }
}
