@page "/ui/logs"
@attribute [Authorize]
@inject LogBufferService LogBuffer
@inject ILogger<Logs> Logger
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using Castr.Services

<PageTitle>Logs - Castr</PageTitle>

<div style="padding:24px 32px 40px;max-width:1180px;height:100%;display:flex;flex-direction:column;min-height:0;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:14px;margin-bottom:18px;flex-shrink:0;">
        <div>
            <h1 class="castr-h1" style="margin:0;">Logs</h1>
            <p class="castr-subtitle" style="margin:5px 0 0;">Live tail of the castr server process · @_shownCount lines</p>
        </div>
        <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
            <button @onclick="ToggleTail"
                    style="display:inline-flex;align-items:center;gap:7px;border-radius:8px;padding:7px 12px;font-size:12.5px;font-weight:600;font-family:inherit;cursor:pointer;@TailBtnStyle">
                <span style="width:7px;height:7px;border-radius:50%;background:@TailDotColor;@TailDotAnim"></span>@(_tailing ? "Tailing" : "Paused")
            </button>
            <button @onclick="ClearLogs"
                    style="display:inline-flex;align-items:center;gap:6px;background:#2a261d;color:#dcd6c8;border:none;border-radius:8px;padding:7px 12px;font-size:12.5px;font-weight:600;font-family:inherit;cursor:pointer;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M6 6l1 14h10l1-14"/></svg>
                Clear
            </button>
        </div>
    </div>

    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:12px;flex-shrink:0;">
        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
            @foreach (var lvl in _levelChips)
            {
                var active = _level == lvl.Key;
                <button @onclick="() => SetLevel(lvl.Key)"
                        style="display:inline-flex;align-items:center;gap:7px;border-radius:999px;padding:5px 11px;font-size:12.5px;font-weight:600;font-family:inherit;cursor:pointer;background:@(active ? "#26221a" : "transparent");color:@(active ? "#f6f3ec" : "#9a9384");border:1px solid @(active ? "#3a342a" : "#2a261d");">
                    @lvl.Label<span class="castr-mono" style="font-size:11px;color:@(active ? "#b4ad9e" : "#5e584c");">@CountFor(lvl.Key)</span>
                </button>
            }
        </div>
        <div style="position:relative;margin-left:auto;width:220px;" class="d-none d-sm-block">
            <span style="position:absolute;left:11px;top:50%;transform:translateY(-50%);color:#5e584c;display:flex;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="21" y2="21"/></svg></span>
            <input value="@_query" @oninput="OnSearch" placeholder="Filter lines…"
                   style="width:100%;background:#1d1b14;border:1px solid #2a261d;border-radius:8px;padding:7px 11px 7px 32px;color:#f4f1ea;font-size:12.5px;font-family:'JetBrains Mono',monospace;outline:none;" />
        </div>
    </div>

    <div id="castr-log-scroll" style="flex:1;min-height:0;overflow-y:auto;background:#100f0a;border:1px solid #28241c;border-radius:14px;padding:8px 0;">
        @{
            var lines = FilteredLines();
        }
        @if (lines.Count == 0)
        {
            <div style="padding:44px;text-align:center;color:#645e52;font-size:14px;">No log lines match this filter.</div>
        }
        else
        {
            @foreach (var g in lines)
            {
                <div style="display:grid;grid-template-columns:78px 88px 92px 1fr;gap:12px;align-items:baseline;padding:3px 16px;background:@RowBg(g.Level);font-family:'JetBrains Mono',monospace;font-size:12.5px;line-height:1.55;">
                    <span style="color:#5e584c;white-space:nowrap;">@g.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                    <span style="color:@LevelColor(g.Level);font-weight:600;letter-spacing:.03em;white-space:nowrap;">@LevelLabel(g.Level)</span>
                    <span class="d-none d-sm-block" style="color:#6a6456;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@ShortSource(g.Category)</span>
                    <span style="color:#cfc9bb;word-break:break-word;">@g.Message</span>
                </div>
            }
            @if (_tailing)
            {
                <div style="display:flex;align-items:center;gap:8px;padding:4px 16px;font-family:'JetBrains Mono',monospace;font-size:12.5px;color:#5e584c;">
                    <span style="color:var(--accent,#ef6b41);">castr$</span>
                    <span style="width:8px;height:15px;background:var(--accent,#ef6b41);animation:onair 1.1s steps(1) infinite;"></span>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<LogEntry> _entries = new();
    private string _level = "all";
    private bool _tailing = true;
    private string _query = "";
    private int _shownCount;

    // Lines captured at the moment of "Clear" — we hide everything at/before this timestamp.
    private DateTime _clearedBefore = DateTime.MinValue;

    private HubConnection? _hubConnection;
    private bool _pendingScroll;

    private readonly (string Key, string Label)[] _levelChips =
    {
        ("all", "All"), ("download", "Downloads"), ("info", "Info"), ("warn", "Warnings"), ("error", "Errors")
    };

    protected override async Task OnInitializedAsync()
    {
        _entries = LogBuffer.Snapshot().ToList();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/logs"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<DateTime, int, string, string>("LogEntry", async (ts, level, category, message) =>
        {
            if (!_tailing) return;

            _entries.Add(new LogEntry(ts, (LogLevel)level, category, message));
            if (_entries.Count > LogBufferService.Capacity)
            {
                _entries.RemoveRange(0, _entries.Count - LogBufferService.Capacity);
            }
            _pendingScroll = true;
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to connect to log stream hub");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if ((firstRender || _pendingScroll) && _tailing)
        {
            _pendingScroll = false;
            try
            {
                await JS.InvokeVoidAsync("castrScrollToBottom", "castr-log-scroll");
            }
            catch (Exception)
            {
                // JS interop may be unavailable during prerender; ignore.
            }
        }
    }

    // Classify a captured entry into one of the design's filter groups.
    private static string GroupOf(LogEntry e)
    {
        if (e.Level >= LogLevel.Error) return "error";
        if (e.Level == LogLevel.Warning) return "warn";
        if (IsDownloadCategory(e.Category)) return "download";
        return "info";
    }

    private static bool IsDownloadCategory(string category) =>
        category.Contains("YouTubeDownload", StringComparison.OrdinalIgnoreCase) ||
        category.Contains("PlaylistWatcher", StringComparison.OrdinalIgnoreCase) ||
        category.Contains("Download", StringComparison.OrdinalIgnoreCase);

    private IEnumerable<LogEntry> Visible() =>
        _entries.Where(e => e.Timestamp > _clearedBefore);

    private List<LogEntry> FilteredLines()
    {
        var q = _query.Trim();
        var result = Visible()
            .Where(e => _level == "all" || GroupOf(e) == _level)
            .Where(e => string.IsNullOrEmpty(q)
                || e.Message.Contains(q, StringComparison.OrdinalIgnoreCase)
                || e.Category.Contains(q, StringComparison.OrdinalIgnoreCase))
            .ToList();
        _shownCount = result.Count;
        return result;
    }

    private int CountFor(string key)
    {
        var visible = Visible();
        if (key == "all") return visible.Count();
        return visible.Count(e => GroupOf(e) == key);
    }

    private static string LevelLabel(LogLevel level) => level switch
    {
        LogLevel.Critical => "CRIT",
        LogLevel.Error => "ERROR",
        LogLevel.Warning => "WARN",
        LogLevel.Information => "INFO",
        LogLevel.Debug => "DEBUG",
        LogLevel.Trace => "TRACE",
        _ => level.ToString().ToUpperInvariant()
    };

    private static string LevelColor(LogLevel level) => level switch
    {
        LogLevel.Critical or LogLevel.Error => "#e0614f",
        LogLevel.Warning => "#e0b04a",
        LogLevel.Information => "#7f9fc0",
        _ => "#8b8475"
    };

    private static string RowBg(LogLevel level) => level switch
    {
        LogLevel.Critical or LogLevel.Error => "rgba(224,97,79,.07)",
        LogLevel.Warning => "rgba(224,176,74,.06)",
        _ => "transparent"
    };

    private static string ShortSource(string category)
    {
        var idx = category.LastIndexOf('.');
        return idx >= 0 && idx < category.Length - 1 ? category[(idx + 1)..] : category;
    }

    private string TailBtnStyle => _tailing
        ? "background:rgba(91,191,138,.1);color:#83cda4;border:1px solid rgba(91,191,138,.25);"
        : "background:#2a261d;color:#dcd6c8;border:1px solid #2a261d;";

    private string TailDotColor => _tailing ? "#5bbf8a" : "#8b8475";
    private string TailDotAnim => _tailing ? "animation:onair 1.6s ease-in-out infinite;" : "";

    private void ToggleTail()
    {
        _tailing = !_tailing;
        if (_tailing)
        {
            // Re-sync to the latest buffer so paused-period lines appear.
            _entries = LogBuffer.Snapshot().ToList();
            _pendingScroll = true;
        }
    }

    private void ClearLogs()
    {
        // Client-side clear only: hide everything currently buffered for this client.
        _clearedBefore = _entries.Count > 0 ? _entries[^1].Timestamp : DateTime.UtcNow;
        _query = "";
        _level = "all";
    }

    private void SetLevel(string key) => _level = key;

    private void OnSearch(ChangeEventArgs e) => _query = e.Value?.ToString() ?? "";

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
