@page "/ui/downloads"
@attribute [Authorize]
@inject IPodcastDataService DataService
@inject ILogger<Downloads> Logger
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using Castr.Data.Entities
@using DownloadQueueItemEntity = Castr.Data.Entities.DownloadQueueItem

<PageTitle>Downloads - Castr</PageTitle>

<div class="castr-page castr-page--narrow">
    <h1 class="castr-h1">Downloads</h1>
    <p class="castr-subtitle" style="margin-bottom:22px;">Live queue from the playlist watcher.</p>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <div class="castr-tabs">
            @foreach (var tab in _tabs)
            {
                <button class="castr-tab @(_selectedTab == tab.Key ? "castr-tab--active" : "")"
                        @onclick="() => _selectedTab = tab.Key">
                    @tab.Label
                    <span class="castr-count-badge @(_selectedTab == tab.Key ? "" : "castr-count-badge--neutral")">@TabCount(tab.Key)</span>
                </button>
            }
        </div>

        <div class="castr-card" style="padding:0;overflow:hidden;">
            @{
                var shown = ShownItems();
            }
            @if (shown.Count == 0)
            {
                <div style="padding:44px;text-align:center;color:var(--text-faint);font-size:14px;">Nothing here right now.</div>
            }
            else
            {
                @foreach (var item in shown)
                {
                    <div style="padding:16px 18px;border-bottom:1px solid var(--border-row);">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:14px;">
                            <div style="display:flex;align-items:center;gap:12px;min-width:0;">
                                <div class="castr-avatar" style="width:34px;height:34px;border-radius:8px;background:@FeedColor(_feedNames.GetValueOrDefault(item.FeedId, "?"));"></div>
                                <div style="min-width:0;">
                                    <div style="font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@(item.VideoTitle ?? item.VideoId)</div>
                                    <div style="font-size:12px;color:var(--text-label);">
                                        @(_feedNames.GetValueOrDefault(item.FeedId, "Unknown"))
                                        @if (item.Status == "queued")
                                        {
                                            <span> · queued @item.QueuedAt.ToString("g")</span>
                                        }
                                        else if (item.Status == "completed" && item.CompletedAt.HasValue)
                                        {
                                            <span> · @item.CompletedAt.Value.ToString("g")</span>
                                        }
                                    </div>
                                    @if (item.Status == "failed" && !string.IsNullOrEmpty(item.ErrorMessage))
                                    {
                                        <div style="font-size:11.5px;color:var(--status-error);margin-top:2px;">@item.ErrorMessage</div>
                                    }
                                </div>
                            </div>
                            <div style="display:flex;align-items:center;gap:10px;flex-shrink:0;">
                                <div class="castr-mono" style="text-align:right;">
                                    <div style="font-size:13.5px;font-weight:600;color:@MetaColor(item.Status);">@MetaMain(item)</div>
                                    <div style="font-size:11px;color:var(--text-faint);">@MetaSub(item)</div>
                                </div>
                                @if (item.Status == "queued")
                                {
                                    <button class="castr-icon-btn" title="Cancel" @onclick="() => CancelDownload(item)">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
                                    </button>
                                }
                                else if (item.Status == "failed")
                                {
                                    <button class="castr-icon-btn" title="Retry" @onclick="() => RetryDownload(item)">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v5h-5"/></svg>
                                    </button>
                                    <button class="castr-icon-btn" title="Remove" @onclick="() => RemoveFromQueue(item)">
                                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M6 6l1 14h10l1-14"/></svg>
                                    </button>
                                }
                            </div>
                        </div>
                        @if (item.Status == "downloading")
                        {
                            <div class="castr-rail castr-rail--thin" style="margin-top:11px;">
                                <div class="castr-rail__fill" style="width:@(item.ProgressPercent)%;"></div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private List<DownloadQueueItemEntity> _activeDownloads = new();
    private List<DownloadQueueItemEntity> _queuedDownloads = new();
    private List<DownloadQueueItemEntity> _completedDownloads = new();
    private List<DownloadQueueItemEntity> _failedDownloads = new();
    private Dictionary<int, string> _feedNames = new();
    private bool _loading = true;
    private HubConnection? _hubConnection;
    private System.Threading.Timer? _refreshTimer;
    private bool _disposed;

    private string _selectedTab = "active";
    private readonly (string Key, string Label)[] _tabs =
    {
        ("active", "Active"), ("queued", "Queued"), ("completed", "Completed"), ("failed", "Failed")
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();

        // Set up SignalR connection
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/download-progress"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<int, string, int>("DownloadProgress", async (feedId, videoId, percent) =>
        {
            var item = _activeDownloads.FirstOrDefault(x => x.VideoId == videoId);
            if (item != null)
            {
                item.ProgressPercent = percent;
                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<int, string, string>("DownloadCompleted", async (feedId, videoId, filename) =>
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<int, string, string>("DownloadFailed", async (feedId, videoId, error) =>
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to connect to SignalR hub");
        }

        // Refresh every 10 seconds
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            try
            {
                await LoadDataAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch (ObjectDisposedException)
            {
                // Expected during disposal, ignore
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error in downloads refresh timer");
            }
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var feeds = await DataService.GetAllFeedsAsync();
            _feedNames = feeds.ToDictionary(f => f.Id, f => f.Title);

            var queue = await DataService.GetQueueAsync();

            _activeDownloads = queue.Where(q => q.Status == "downloading").ToList();
            _queuedDownloads = queue.Where(q => q.Status == "queued").OrderBy(q => q.QueuedAt).ToList();
            _completedDownloads = queue.Where(q => q.Status == "completed").OrderByDescending(q => q.CompletedAt).ToList();
            _failedDownloads = queue.Where(q => q.Status == "failed").ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load download queue");
        }
        finally
        {
            _loading = false;
        }
    }

    private int TabCount(string key) => key switch
    {
        "active" => _activeDownloads.Count,
        "queued" => _queuedDownloads.Count,
        "completed" => _completedDownloads.Count,
        "failed" => _failedDownloads.Count,
        _ => 0
    };

    private List<DownloadQueueItemEntity> ShownItems() => _selectedTab switch
    {
        "active" => _activeDownloads,
        "queued" => _queuedDownloads,
        "completed" => _completedDownloads.Take(20).ToList(),
        "failed" => _failedDownloads,
        _ => new()
    };

    private static string MetaMain(DownloadQueueItemEntity item) => item.Status switch
    {
        "downloading" => $"{item.ProgressPercent}%",
        "queued" => "Queued",
        "completed" => "Done",
        "failed" => "Failed",
        _ => item.Status
    };

    private static string MetaSub(DownloadQueueItemEntity item) => item.Status switch
    {
        "downloading" => "downloading",
        "queued" => "waiting",
        "completed" => item.CompletedAt?.ToString("t") ?? "",
        "failed" => "see error",
        _ => ""
    };

    private static string MetaColor(string status) => status switch
    {
        "downloading" => "#ef6b41",
        "queued" => "#e0b04a",
        "completed" => "#5bbf8a",
        "failed" => "#e0614f",
        _ => "#928b7c"
    };

    private static readonly string[] AvatarPalette =
        { "#a8794a", "#b5683f", "#4f7d6e", "#8a5168", "#6a6aa3", "#4d7a99" };

    private static string FeedColor(string name)
    {
        if (string.IsNullOrEmpty(name)) return AvatarPalette[0];
        int hash = 0;
        foreach (var c in name) hash = (hash * 31 + c) & 0x7fffffff;
        return AvatarPalette[hash % AvatarPalette.Length];
    }

    private async Task CancelDownload(DownloadQueueItemEntity item)
    {
        try
        {
            await DataService.RemoveFromQueueAsync(item.Id);
            Snackbar.Add("Download cancelled", Severity.Info);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to cancel download");
            Snackbar.Add("Failed to cancel download", Severity.Error);
        }
    }

    private async Task RetryDownload(DownloadQueueItemEntity item)
    {
        try
        {
            await DataService.UpdateQueueProgressAsync(item.Id, "queued", 0, null);
            Snackbar.Add("Download queued for retry", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to retry download");
            Snackbar.Add("Failed to retry download", Severity.Error);
        }
    }

    private async Task RemoveFromQueue(DownloadQueueItemEntity item)
    {
        try
        {
            await DataService.RemoveFromQueueAsync(item.Id);
            Snackbar.Add("Removed from queue", Severity.Info);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to remove from queue");
            Snackbar.Add("Failed to remove from queue", Severity.Error);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _refreshTimer?.Dispose();
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
