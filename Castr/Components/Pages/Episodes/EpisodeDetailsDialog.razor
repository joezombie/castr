@inject ISnackbar Snackbar
@using Castr.Data.Entities

<MudDialog>
    <DialogContent>
        @if (Episode != null)
        {
            <div style="display:flex;flex-direction:column;gap:16px;">

                @if (!string.IsNullOrEmpty(Episode.ThumbnailUrl))
                {
                    <img src="@Episode.ThumbnailUrl" alt="Thumbnail"
                        style="width:100%;max-width:360px;border-radius:11px;border:1px solid var(--border-card);object-fit:contain;" />
                }

                @MetaRow("Filename", Episode.Filename, mono: true)

                @if (!string.IsNullOrEmpty(Episode.YoutubeTitle))
                {
                    @MetaRow("YouTube Title", Episode.YoutubeTitle!)
                }

                @if (!string.IsNullOrEmpty(Episode.VideoId))
                {
                    <div>
                        <div class="castr-section-label">YouTube Video</div>
                        <a href="@($"https://youtube.com/watch?v={Episode.VideoId}")" target="_blank"
                            class="castr-mono" style="color:var(--accent);text-decoration:none;font-size:13.5px;">
                            @Episode.VideoId
                        </a>
                    </div>
                }

                @MetaRow("Display Order", Episode.DisplayOrder.ToString(), mono: true)

                @if (Episode.PublishDate.HasValue)
                {
                    @MetaRow("Publish Date", Episode.PublishDate.Value.ToString("f"), mono: true)
                }

                @MetaRow("Added", Episode.AddedAt.ToString("f"), mono: true)

                @if (Episode.MatchScore.HasValue)
                {
                    @MetaRow("Match Score", $"{(Episode.MatchScore.Value * 100).ToString("F1")}%", mono: true)
                }

                @if (!string.IsNullOrEmpty(Episode.Artist))
                {
                    @MetaRow("Artist", Episode.Artist!)
                }

                @if (!string.IsNullOrEmpty(Episode.Album))
                {
                    @MetaRow("Album", Episode.Album!)
                }

                @if (!string.IsNullOrEmpty(Episode.Genre))
                {
                    @MetaRow("Genre", Episode.Genre!)
                }

                @if (Episode.Year.HasValue)
                {
                    @MetaRow("Year", Episode.Year!.ToString()!, mono: true)
                }

                @if (Episode.TrackNumber.HasValue)
                {
                    @MetaRow("Track #", Episode.TrackNumber!.ToString()!, mono: true)
                }

                @if (Episode.Bitrate.HasValue)
                {
                    @MetaRow("Bitrate", $"{Episode.Bitrate} kbps", mono: true)
                }

                @if (!string.IsNullOrEmpty(Episode.Subtitle))
                {
                    @MetaRow("Subtitle", Episode.Subtitle!)
                }

                @if (!string.IsNullOrEmpty(Episode.Description))
                {
                    <div>
                        <div class="castr-section-label">Description</div>
                        <div style="white-space:pre-wrap;max-height:200px;overflow-y:auto;font-size:13.5px;color:var(--text-value);line-height:1.5;">@Episode.Description</div>
                    </div>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        <button type="button" class="castr-btn castr-btn--secondary" @onclick="Close">Close</button>
    </DialogActions>
</MudDialog>

@{
    RenderFragment MetaRow(string label, string value, bool mono = false) =>
        @<div>
            <div class="castr-section-label">@label</div>
            <div class="@(mono ? "castr-mono" : "")" style="font-size:13.5px;color:var(--text-value);">@value</div>
        </div>;
}

@code {
    [CascadingParameter]
    private MudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public Episode? Episode { get; set; }

    [Parameter]
    public string? FeedName { get; set; }

    private void Close() => MudDialog?.Close();
}
