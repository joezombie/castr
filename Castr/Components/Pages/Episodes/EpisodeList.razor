@page "/ui/feeds/{FeedName}/episodes"
@attribute [Authorize]
@inject IPodcastDataService DataService
@inject ILogger<EpisodeList> Logger
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Castr.Data.Entities

<PageTitle>Episodes - @(_feed?.Title ?? FeedName) - Castr</PageTitle>

<div class="castr-page castr-page--tight">

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
    <div>
        <div class="castr-h1">Episodes</div>
        <div class="castr-subtitle">@(_feed?.Title ?? FeedName)</div>
    </div>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_feed == null)
{
    <MudAlert Severity="Severity.Error">Feed not found</MudAlert>
}
else
{
    <div class="castr-card castr-card--pad20 mb-4">
        <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">
            <MudTextField @bind-Value="_searchText" Label="Search" Variant="Variant.Outlined" Margin="Margin.Dense"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                Immediate="true" DebounceInterval="300" Style="max-width: 300px;" />
            <MudSpacer />
            @if (_selectedEpisodes.Any())
            {
                <button type="button" class="castr-btn castr-btn--secondary" @onclick="RedownloadSelected">
                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" /> Redownload (@_selectedEpisodes.Count)
                </button>
                <button type="button" class="castr-btn castr-btn--danger" @onclick="DeleteSelected">
                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" /> Delete (@_selectedEpisodes.Count)
                </button>
            }
        </MudStack>
    </div>

    <MudDataGrid Items="@FilteredEpisodes" Hover="true" Dense="true" MultiSelection="true"
        @bind-SelectedItems="_selectedEpisodes" SortMode="SortMode.Single" Class="castr-grid" Elevation="0">
        <Columns>
            <SelectColumn T="Episode" />
            <PropertyColumn Property="x => x.DisplayOrder" Title="#" SortBy="x => x.DisplayOrder"
                CellClass="castr-mono" />
            <PropertyColumn Property="x => x.Filename" Title="Filename" />
            <TemplateColumn Title="YouTube Title">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.YoutubeTitle))
                    {
                        <MudText Typo="Typo.body2">@context.Item.YoutubeTitle</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default">—</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Status">
                <CellTemplate>
                    @{
                        var (dotColor, statusLabel) = GetStatusDisplay(context.Item);
                    }
                    <span class="castr-pill">
                        <span class="castr-pill__dot" style="background:@dotColor;"></span>
                        <span class="castr-pill__label">@statusLabel</span>
                    </span>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Publish Date" SortBy="x => x.PublishDate">
                <CellTemplate>
                    @if (context.Item.PublishDate.HasValue)
                    {
                        <span class="castr-mono" style="font-size:12.5px;color:var(--text-muted);">@context.Item.PublishDate.Value.ToString("d")</span>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default">—</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Match">
                <CellTemplate>
                    @if (context.Item.MatchScore.HasValue)
                    {
                        var score = context.Item.MatchScore.Value * 100;
                        var matchColor = score >= 90 ? "var(--status-success)" : score >= 70 ? "var(--status-warning)" : "var(--status-error)";
                        <span class="castr-mono" style="font-size:12.5px;color:@matchColor;">@score.ToString("F0")%</span>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Default">—</MudText>
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Actions">
                <CellTemplate>
                    <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Class="castr-icon-btn"
                            OnClick="() => ViewEpisode(context.Item)" title="View Details" />
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" Class="castr-icon-btn"
                            OnClick="() => RedownloadEpisode(context.Item)" title="Redownload" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Class="castr-icon-btn"
                            OnClick="() => DeleteEpisode(context.Item)" title="Delete" />
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="Episode" />
        </PagerContent>
    </MudDataGrid>
}

</div>

@code {
    [Parameter]
    public string? FeedName { get; set; }

    private Feed? _feed;
    private List<Episode> _episodes = new();
    private HashSet<Episode> _selectedEpisodes = new();
    private string _searchText = "";
    private bool _loading = true;

    private IEnumerable<Episode> FilteredEpisodes => string.IsNullOrWhiteSpace(_searchText)
        ? _episodes
        : _episodes.Where(e =>
            e.Filename.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
            (e.YoutubeTitle?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        if (string.IsNullOrEmpty(FeedName))
        {
            Navigation.NavigateTo("/ui/feeds");
            return;
        }

        try
        {
            _feed = await DataService.GetFeedByNameAsync(FeedName);
            if (_feed == null)
            {
                Snackbar.Add("Feed not found", Severity.Error);
                return;
            }

            _episodes = await DataService.GetEpisodesAsync(_feed.Id);
            _episodes = _episodes.OrderBy(e => e.DisplayOrder).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load episodes for {FeedName}", FeedName);
            Snackbar.Add("Failed to load episodes", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ViewEpisode(Episode episode)
    {
        var parameters = new DialogParameters<EpisodeDetailsDialog>
        {
            { x => x.Episode, episode },
            { x => x.FeedName, _feed?.Title ?? FeedName }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<EpisodeDetailsDialog>("Episode Details", parameters, options);
    }

    private async Task RedownloadEpisode(Episode episode)
    {
        if (_feed == null || string.IsNullOrEmpty(episode.VideoId)) return;

        var result = await DialogService.ShowMessageBox(
            "Redownload Episode",
            $"Are you sure you want to mark '{episode.Filename}' for redownload? The next playlist poll will re-download this video.",
            yesText: "Redownload",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                // Remove from downloaded_videos to trigger redownload
                await DataService.RemoveDownloadedVideoAsync(_feed.Id, episode.VideoId);
                await DataService.LogActivityAsync(_feed.Id, "redownload",
                    $"Marked for redownload: {episode.Filename}");
                Snackbar.Add("Episode marked for redownload. It will be re-downloaded on the next playlist poll.", Severity.Success);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to mark episode for redownload");
                Snackbar.Add("Failed to mark episode for redownload", Severity.Error);
            }
        }
    }

    private async Task DeleteEpisode(Episode episode)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Episode",
            $"Are you sure you want to remove '{episode.Filename}' from the database? This will not delete the file.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await DataService.DeleteEpisodeAsync(episode.Id);
                Snackbar.Add("Episode removed from database", Severity.Success);
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to delete episode {EpisodeId}", episode.Id);
                Snackbar.Add("Failed to delete episode", Severity.Error);
            }
        }
    }

    private async Task RedownloadSelected()
    {
        var withVideoIds = _selectedEpisodes.Where(e => !string.IsNullOrEmpty(e.VideoId)).ToList();
        if (withVideoIds.Count == 0)
        {
            Snackbar.Add("No episodes with video IDs selected", Severity.Warning);
            return;
        }

        var result = await DialogService.ShowMessageBox(
            "Redownload Episodes",
            $"Mark {withVideoIds.Count} episode(s) for redownload?",
            yesText: "Redownload",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                foreach (var episode in withVideoIds)
                {
                    await DataService.RemoveDownloadedVideoAsync(_feed!.Id, episode.VideoId!);
                }
                Snackbar.Add($"{withVideoIds.Count} episode(s) marked for redownload", Severity.Success);
                _selectedEpisodes.Clear();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to mark episodes for redownload");
                Snackbar.Add("Failed to mark episodes for redownload", Severity.Error);
            }
        }
    }

    private async Task DeleteSelected()
    {
        if (!_selectedEpisodes.Any()) return;

        var count = _selectedEpisodes.Count;
        var result = await DialogService.ShowMessageBox(
            "Delete Episodes",
            $"Remove {count} episode(s) from database? This will not delete the files.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                foreach (var episode in _selectedEpisodes)
                {
                    await DataService.DeleteEpisodeAsync(episode.Id);
                }
                Snackbar.Add($"{count} episode(s) removed from database", Severity.Success);
                _selectedEpisodes.Clear();
                await LoadDataAsync();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to delete episodes");
                Snackbar.Add("Failed to delete episodes", Severity.Error);
            }
        }
    }

    private void GoBack() => Navigation.NavigateTo($"/ui/feeds/{FeedName}");

    // Derives a status dot color + label from the data available on an episode.
    // Episodes in this list represent downloaded files in the database.
    private (string Color, string Label) GetStatusDisplay(Episode episode)
    {
        if (string.IsNullOrEmpty(episode.VideoId))
        {
            // No YouTube link; a plain local file present in the directory.
            return ("var(--status-warning)", "Local");
        }
        // Linked to a YouTube video and present in the database = downloaded.
        return ("var(--status-success)", "Downloaded");
    }
}
