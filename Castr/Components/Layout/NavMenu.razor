@inject NavigationManager Navigation
@inject Castr.Services.LogBufferService LogBuffer
@implements IDisposable

<div style="display:flex;flex-direction:column;height:100%;padding:18px 14px;box-sizing:border-box;">

    <!-- logo tile -->
    <div style="display:flex;align-items:center;gap:9px;padding:6px 8px 18px;">
        <div style="width:26px;height:26px;border-radius:7px;background:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <div style="width:8px;height:8px;border-radius:50%;background:#18160f;"></div>
        </div>
        <span style="font-size:19px;font-weight:800;letter-spacing:-.02em;color:#f4f1ea;">Castr</span>
    </div>

    <div style="font-size:10.5px;font-weight:600;letter-spacing:.1em;color:#5e584c;padding:6px 11px 8px;">MANAGE</div>

    <nav style="display:flex;flex-direction:column;gap:3px;">
        @NavItem("/ui", true, "Overview",
            "<rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1.6\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1.6\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1.6\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1.6\"/>")
        @NavItem("/ui/feeds", false, "Feeds",
            "<circle cx=\"5\" cy=\"19\" r=\"1.6\"/><path d=\"M4 11a9 9 0 0 1 9 9\"/><path d=\"M4 4a16 16 0 0 1 16 16\"/>")
        @NavItem("/ui/downloads", false, "Downloads",
            "<path d=\"M12 3v12\"/><path d=\"M8 11l4 4 4-4\"/><path d=\"M5 21h14\"/>")
        @NavItem("/ui/logs", false, "Logs",
            "<path d=\"M4 17l5-5-5-5\"/><line x1=\"12\" y1=\"19\" x2=\"20\" y2=\"19\"/>", HasLogAlerts())
        @NavItem("/ui/settings", false, "Settings",
            "<line x1=\"4\" y1=\"7\" x2=\"20\" y2=\"7\"/><line x1=\"4\" y1=\"12\" x2=\"20\" y2=\"12\"/><line x1=\"4\" y1=\"17\" x2=\"20\" y2=\"17\"/><circle cx=\"9\" cy=\"7\" r=\"2.3\" fill=\"#18160f\"/><circle cx=\"15\" cy=\"12\" r=\"2.3\" fill=\"#18160f\"/><circle cx=\"8\" cy=\"17\" r=\"2.3\" fill=\"#18160f\"/>")
    </nav>

    <div style="margin-top:auto;display:flex;flex-direction:column;gap:12px;">
        <!-- user row -->
        <div style="display:flex;align-items:center;gap:9px;padding:4px 6px;">
            <div style="width:30px;height:30px;border-radius:50%;background:#2a261d;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#b4ad9e;flex-shrink:0;">A</div>
            <div style="line-height:1.25;min-width:0;">
                <div style="font-size:13px;font-weight:600;color:#f4f1ea;">admin</div>
                <div style="font-size:11px;color:#645e52;">Administrator</div>
            </div>
            <a href="/ui/logout" title="Logout" @onclick="OnNavLinkClick"
               style="margin-left:auto;cursor:pointer;color:#645e52;display:flex;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
            </a>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Action? CloseDrawer { get; set; }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private bool IsActive(string href, bool exact)
    {
        var path = "/" + Navigation.ToBaseRelativePath(Navigation.Uri).Split('?')[0].TrimEnd('/');
        if (path == "/") path = "/";
        if (exact)
            return string.Equals(path, href, StringComparison.OrdinalIgnoreCase);
        return path.StartsWith(href, StringComparison.OrdinalIgnoreCase);
    }

    private RenderFragment NavItem(string href, bool exact, string label, string svgInner, bool alertDot = false) => builder =>
    {
        var active = IsActive(href, exact);
        var bg = active ? "#26221a" : "transparent";
        var color = active ? "#f6f3ec" : "#9a9384";
        var style = $"display:flex;align-items:center;gap:11px;padding:9px 11px;border-radius:9px;font-size:14.5px;font-weight:500;cursor:pointer;text-decoration:none;transition:background .15s,color .15s;background:{bg};color:{color};";

        builder.OpenElement(0, "a");
        builder.AddAttribute(1, "href", href);
        builder.AddAttribute(2, "style", style);
        builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, OnNavLinkClick));
        // icon
        builder.AddMarkupContent(4,
            $"<svg width=\"17\" height=\"17\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\">{svgInner}</svg>");
        builder.AddContent(5, label);
        if (alertDot)
        {
            builder.AddMarkupContent(6,
                "<span style=\"margin-left:auto;width:7px;height:7px;border-radius:50%;background:#e0614f;\"></span>");
        }
        builder.CloseElement();
    };

    private bool HasLogAlerts() =>
        LogBuffer.Snapshot().Any(e => e.Level >= LogLevel.Error);

    private void OnNavLinkClick()
    {
        CloseDrawer?.Invoke();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
